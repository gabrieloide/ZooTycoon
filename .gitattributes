# Normalize line endings to LF
* text=auto eol=lf

# Unity YAML files shouldn't be touched by Git
*.meta -text
*.unity -text
*.asset -text
*.prefab -text
*.mat -text
*.anim -text
*.controller -text
*.overrideController -text
*.physicMaterial -text
*.physicsMaterial2D -text
*.scenetemplate -text

# Image files
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
